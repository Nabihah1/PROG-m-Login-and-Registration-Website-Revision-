@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<header style="background: linear-gradient(135deg, #d1c4e9, #b39ddb);  color: white; text-align: center; padding: 100px 20px;">
    <h1 style="font-size: 3em; margin-bottom: 20px;">Welcome</h1>
    <p style="font-size: 1.2em; margin-bottom: 30px;">Start your journey here</p>
    <a href="/Home/Index" style="background-color: black; color: white; padding: 15px 30px; text-decoration: none; border-radius: 5px;">Get Started</a>
</header>

<!-- Features Section -->
<section style="text-align: center; padding: 60px 20px;">
    <h2 style="margin-bottom: 40px;">Why Choose Us?</h2>
    <div style="display: flex; justify-content: center; gap: 20px; flex-wrap: wrap;">
        <div style="background: purple; padding: 20px; border-radius: 5px; width: 200px; color:white">
            <h3>Easy to Use</h3>
            <p>Simple interface for everyone.</p>
        </div>
        <div style="background: purple; padding: 20px; border-radius: 5px; width: 200px; color:white">
            <h3>Secure</h3>
            <p>Your data is safe with us.</p>
        </div>
        <div style="background: purple; padding: 20px; border-radius: 5px; width: 200px; color:white">
            <h3>Reliable</h3>
            <p>Fast and dependable performance.</p>
        </div>
    </div>
</section>


<section style="background: linear-gradient(135deg, #d1c4e9, #b39ddb);  color: white; text-align: center; padding: 60px 20px;">
    <h2>Ready to Begin?</h2>
    <p>Explore our features and get started today!</p>
    <a href="/Home/Index" style="background-color: black; color: white; padding: 15px 30px; text-decoration: none; border-radius: 5px;">Learn More</a>
</section>